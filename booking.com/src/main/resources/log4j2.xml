<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    
    <Appenders>

    <Console name="Console" target="SYSTEM_OUT">
        <PatternLayout pattern="%d{HH:mm:ss} [%t] %-5level %X{testName} %logger - %msg%n"/>
    </Console>

    <Routing name="RoutingAppender">
        <Routes pattern="$${ctx:logFileName}">
            <Route>
                <File name="FileAppender-${ctx:logPath}"
                       fileName="${ctx:logPath}/${ctx:logFileName}.log">
                    <PatternLayout pattern="%d{HH:mm:ss} [%t] %-5level %X{testName} - %msg%n"/>
                </File>
            </Route>
        </Routes>
    </Routing>

</Appenders>
    
    

   <Loggers>
    <Root level="info">
        <AppenderRef ref="Console"/>
        <AppenderRef ref="RoutingAppender"/>
    </Root>
</Loggers>

</Configuration>